{
  "name": "fpp-flasher",
  "version": "0.0.0",
  "description": "FPP Flasher — Download and flash FPP-OS to a USB drive or FPP to SD card",
  "author": "jessica12ryan",
  "repository": {
    "type": "git",
    "url": "https://github.com/jessica12ryan/fpp-os.git"
  },
  "build": {
      "appId": "com.jessica12ryan.fpp-flasher",
      "mac": {
        "target": [
          { "target": "dmg", "arch": ["x64", "arm64"] },
          { "target": "zip", "arch": ["x64", "arm64"] }
        ],
        "hardenedRuntime": true,
        "gatekeeperAssess": false,
        "entitlements": "entitlements.mac.plist",
        "entitlementsInherit": "entitlements.mac.plist",
        "identity": null
      }
    },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "sudo-prompt": "^9.2.1"
  }
}
