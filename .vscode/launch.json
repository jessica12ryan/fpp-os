{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Flasher",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/flasher",
      "runtimeExecutable": "${workspaceFolder}/flasher/node_modules/.bin/electron",
      "runtimeArgs": ["."],
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/flasher/node_modules/.bin/electron.cmd"
      },
      "console": "integratedTerminal"
    }
  ]
}
